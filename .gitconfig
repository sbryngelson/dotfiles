[user]
	name = Spencer Bryngelson
	email = sbryngelson@gmail.com
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[color]
  diff = auto
  status = auto
  branch = auto
  interactive = auto
  ui = true
  pager = true
[pull]
	rebase = false
[init]
	defaultBranch = master
[url "https://"]
	insteadOf = git://
# Machine-specific config (credential helpers, tool paths, http tweaks) lives in
# ~/.gitconfig.local, which is gitignored so it doesn't travel between machines.
[include]
	path = ~/.gitconfig.local

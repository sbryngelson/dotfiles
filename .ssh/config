# ----------------------------
# TAMU (HPRC ACES)
# ----------------------------
Host aces-jump
    HostName aces-jump.hprc.tamu.edu
    User u.sb27915
    IdentityFile ~/.ssh/id_aces_tamu
    IdentitiesOnly yes
    Port 8822
    MACs hmac-sha1,hmac-sha2-256,hmac-sha2-512

Host aces1
    HostName login.aces.hprc.tamu.edu
    ProxyJump aces-jump
    User u.sb27915
    IdentityFile ~/.ssh/id_aces_tamu
    IdentitiesOnly yes
    MACs hmac-sha1,hmac-sha2-256,hmac-sha2-512

Host aces
    HostName login.aces.hprc.tamu.edu
    ProxyJump aces-jump
    User u.sb27915
    IdentityFile ~/.ssh/id_aces_tamu
    IdentitiesOnly yes
    RequestTTY yes
    RemoteCommand ssh alogin1
    MACs hmac-sha1,hmac-sha2-256,hmac-sha2-512


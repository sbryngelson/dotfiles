# ~/.ssh/config

Host *
    ServerAliveInterval 60
    ServerAliveCountMax 2

# ----------------------------
# Personal / Public
# ----------------------------

Host amd
    HostName hpcfund.amd.com
    User sbryngelson

Host sephiroth sephiroth.viewdns.net
    HostName sephiroth.viewdns.net
    Port 2611
    IdentityFile ~/.ssh/id_rsa

Host github.com
    HostName ssh.github.com
    Port 443
    User git

Host oci-ubuntu-tunnel
    HostName localhost
    Port 2222
    User ubuntu
    IdentityFile ~/.ssh/id_ed25519

# ----------------------------
# OLCF (ORNL)
# ----------------------------

Host frontier summit crusher ascent wombat andes
    User sbryngelson
    ForwardAgent yes

# hosts that follow "<alias>.olcf.ornl.gov"
Host crusher andes
    HostName %h.olcf.ornl.gov

Host frontier
    HostName login10.frontier.olcf.ornl.gov

Host ascent
    HostName login1.ascent.olcf.ornl.gov

Host wombat
    HostName wombat-login1.ccs.ornl.gov

# ----------------------------
# Georgia Tech
# ----------------------------

Host wingtip instinct rogue phoenix phoenix2 ice
    User sbryngelson3
    ForwardAgent yes

Host wingtip
    HostName wingtip-gpu3.cc.gatech.edu

Host instinct
    HostName instinct.crnch.gatech.edu

Host rogue
    HostName rg-login.crnch.gatech.edu
    IdentityFile ~/.ssh/long

# PACE jump hosts (all go through rogue + X11)
Host phoenix phoenix2 ice wingtip
    ProxyJump rogue
    ForwardX11 yes
    ForwardX11Trusted yes

Host phoenix
    HostName login-phoenix-gnr-1.pace.gatech.edu

Host atl1-*
    User sbryngelson3
    ProxyJump phoenix
    ForwardAgent yes

Host phoenix2
    HostName login-phoenix-gnr-2.pace.gatech.edu

Host ice
    HostName login-ice-2.pace.gatech.edu

